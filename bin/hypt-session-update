#!/usr/bin/env bash
# hypt-session-update — auto-update hypt on session start
#
# Called by Claude Code SessionStart hook. Must be fast, silent, non-fatal.
# The entire update runs in background (forked). The hook itself exits
# immediately so session startup is never delayed.
#
# Exit 0 always — errors must never block a Claude Code session.

set +e

# Auto-detect repo location
HYPT_DIR="${HYPT_DIR:-}"
if [ -z "$HYPT_DIR" ]; then
  if [ -d "$HOME/.claude/plugins/marketplaces/hypt-builder/.git" ]; then
    HYPT_DIR="$HOME/.claude/plugins/marketplaces/hypt-builder"
  elif [ -d "$HOME/.hypt/repo/.git" ]; then
    HYPT_DIR="$HOME/.hypt/repo"
  else
    exit 0
  fi
fi
STATE_DIR="${HYPT_STATE_DIR:-$HOME/.hypt}"
THROTTLE_FILE="$STATE_DIR/.last-session-update"
THROTTLE_SECONDS=3600  # 1 hour

# ── Guard: hypt must be a git repo ──
if [ ! -d "$HYPT_DIR/.git" ]; then
  exit 0
fi

# ── Guard: auto_upgrade must be enabled ──
AUTO=$("$HYPT_DIR/bin/hypt-config" get auto_upgrade 2>/dev/null || true)
if [ "$AUTO" != "true" ]; then
  exit 0
fi

# ── Throttle: skip if checked recently ──
if [ -f "$THROTTLE_FILE" ]; then
  LAST=$(cat "$THROTTLE_FILE" 2>/dev/null || echo 0)
  NOW=$(date +%s)
  ELAPSED=$(( NOW - LAST ))
  if [ "$ELAPSED" -lt "$THROTTLE_SECONDS" ]; then
    exit 0
  fi
fi

# ── Fork to background: zero latency on session start ──
(
  # Prevent git from prompting for credentials
  export GIT_TERMINAL_PROMPT=0

  mkdir -p "$STATE_DIR"

  # ── Pull latest ──
  OLD_HEAD=$(git -C "$HYPT_DIR" rev-parse HEAD 2>/dev/null)
  git -C "$HYPT_DIR" pull --ff-only -q 2>/dev/null
  PULL_EXIT=$?
  NEW_HEAD=$(git -C "$HYPT_DIR" rev-parse HEAD 2>/dev/null)

  # Record check time regardless of outcome
  date +%s > "$THROTTLE_FILE" 2>/dev/null

  if [ "$PULL_EXIT" -ne 0 ]; then
    exit 0
  fi

  # ── If HEAD moved, re-run install ──
  if [ "$OLD_HEAD" != "$NEW_HEAD" ]; then
    # Save old version for the "just upgraded" marker
    OLD_VER=$(git -C "$HYPT_DIR" show "$OLD_HEAD:VERSION" 2>/dev/null || echo "unknown")

    # Re-run install to refresh cache and configs
    bash "$HYPT_DIR/install.sh" >/dev/null 2>&1 || true

    # Write marker so next skill preamble shows "just upgraded"
    echo "$OLD_VER" > "$STATE_DIR/just-upgraded-from" 2>/dev/null
    rm -f "$STATE_DIR/last-update-check" 2>/dev/null
  fi
) &

exit 0
