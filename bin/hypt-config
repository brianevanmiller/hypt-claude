#!/usr/bin/env bash
# hypt-config — get/set config values in ~/.hypt/config.json
#
# Usage:
#   hypt-config get <key>          # print value (or empty if missing)
#   hypt-config set <key> <value>  # write value
set -euo pipefail

ACTION="${1:-}"
KEY="${2:-}"
VALUE="${3:-}"
CONFIG_FILE="${HYPT_STATE_DIR:-$HOME/.hypt}/config.json"

if [ -z "$ACTION" ] || [ -z "$KEY" ]; then
  echo "Usage: hypt-config {get|set} <key> [value]" >&2
  exit 1
fi

case "$ACTION" in
  get)
    if [ ! -f "$CONFIG_FILE" ]; then
      exit 0
    fi
    HYPT_CONFIG_FILE="$CONFIG_FILE" HYPT_KEY="$KEY" node -e "
const fs = require('fs');
try {
  const cfg = JSON.parse(fs.readFileSync(process.env.HYPT_CONFIG_FILE, 'utf8'));
  const v = cfg[process.env.HYPT_KEY];
  if (v === undefined || v === null || v === '') process.exit(0);
  if (typeof v === 'boolean') console.log(v.toString());
  else console.log(v);
} catch(e) {}
"
    ;;
  set)
    if [ -z "$VALUE" ]; then
      echo "Usage: hypt-config set <key> <value>" >&2
      exit 1
    fi
    mkdir -p "$(dirname "$CONFIG_FILE")"
    HYPT_CONFIG_FILE="$CONFIG_FILE" HYPT_KEY="$KEY" HYPT_VALUE="$VALUE" node -e "
const fs = require('fs');
const configFile = process.env.HYPT_CONFIG_FILE;
const key = process.env.HYPT_KEY;
let value = process.env.HYPT_VALUE;

let cfg = {};
try { cfg = JSON.parse(fs.readFileSync(configFile, 'utf8')); } catch(e) {}

if (value.toLowerCase() === 'true' || value.toLowerCase() === 'false')
  value = value.toLowerCase() === 'true';

cfg[key] = value;

const tmp = configFile + '.tmp';
fs.writeFileSync(tmp, JSON.stringify(cfg, null, 2) + '\n');
fs.renameSync(tmp, configFile);
"
    ;;
  *)
    echo "Unknown action: $ACTION (expected get or set)" >&2
    exit 1
    ;;
esac
